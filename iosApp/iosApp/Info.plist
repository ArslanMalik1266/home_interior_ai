<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDisplayName</key>
    <string>Interiorism AI</string>
    <key>CADisableMinimumFrameDurationOnPhone</key>
    <true/>
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
    </dict>
    <key>UIBackgroundModes</key>
    <array>
        <string>remote-notification</string>
        <string>fetch</string>
        <string>processing</string>
    </array>
    <key>BGTaskSchedulerPermittedIdentifiers</key>
    <array>
        <string>com.webscare.interiorismai.imageProcessing</string>
        <string>com.webscare.interiorismai.checkStatus</string>
    </array>

    <!-- ✅ YE ADD KARO — Gallery save ke liye zaroori -->
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>App needs access to save generated interior images to your gallery</string>

    <!-- ✅ YE BHI ADD KARO — Agar gallery read bhi karte ho -->
    <key>NSPhotoLibraryUsageDescription</key>
    <string>App needs access to your photo library</string>
</dict>
</plist>
